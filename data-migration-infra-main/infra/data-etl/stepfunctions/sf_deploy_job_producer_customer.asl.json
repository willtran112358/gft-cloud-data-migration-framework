{
    "Comment": "A description of my state machine",
    "StartAt": "EKS Call",
    "States": {
        "EKS Call": {
            "Type": "Task",
            "Resource": "arn:aws:states:::eks:call",
            "Parameters": {
                "CertificateAuthority": "",
                "ClusterName": "gft-dm-data-migration",
                "Endpoint": "https://763824088AD2AA0A6791099333880C05.gr7.ap-southeast-1.eks.amazonaws.com",
                "Method": "DELETE",
                "Path": "/apis/batch/v1/namespaces/dataloader/jobs/customer-producer",
                "QueryParameters": {
                    "propagationPolicy": [
                        "Foreground"
                    ]
                }
            },
            "Next": "Run Customer Producer",
            "ResultPath": "$.response",
            "Catch": [
                {
                    "ErrorEquals": [
                        "States.ALL"
                    ],
                    "Comment": "pass",
                    "Next": "Run Customer Producer",
                    "ResultPath": "$.response"
                }
            ]
        },
        "Run Customer Producer": {
            "End": true,
            "Parameters": {
                "CertificateAuthority": "",
                "ClusterName": "gft-dm-data-migration",
                "Endpoint": "${eks_endpoint}",
                "Job": {
                    "apiVersion": "batch/v1",
                    "kind": "Job",
                    "metadata": {
                        "name": "customer-producer",
                        "namespace": "dataloader"
                    },
                    "spec": {
                        "backoffLimit": 3,
                        "template": {
                            "spec": {
                                "containers": [
                                    {
                                        "env": [
                                            {
                                                "name": "BATCH_SIZE",
                                                "value.$": "$.size"
                                            },
                                            {
                                                "name": "PRODUCTOR_QUERY",
                                                "value.$": "$.query"
                                            }
                                        ],
                                        "image": "${sf_deploy_job_producer_customer_image}",
                                        "name": "customer-producer",
                                        "imagePullPolicy": "Always"
                                    }
                                ],
                                "nodeSelector": {
                                    "eks.amazonaws.com/nodegroup": "private-nodes"
                                },
                                "restartPolicy": "Never",
                                "serviceAccountName": "data-migration-services"
                            }
                        }
                    }
                },
                "Namespace": "dataloader"
            },
            "Resource": "arn:aws:states:::eks:runJob.sync",
            "ResultPath": "$.response",
            "Type": "Task"
        }
    }
}