{
  "Comment": "A description of my state machine",
  "StartAt": "Parallel",
  "States": {
    "Parallel": {
      "Type": "Parallel",
      "Branches": [
        {
          "StartAt": "EKS delete customer job",
          "States": {
            "EKS delete customer job": {
              "Catch": [
                {
                  "Comment": "eks job doesn't exist",
                  "ErrorEquals": [
                    "States.TaskFailed"
                  ],
                  "Next": "Run Global Reconciliation Customer"
                }
              ],
              "Parameters": {
                "CertificateAuthority": "",
                "ClusterName": "data-migration",
                "Endpoint": "${eks_endpoint}",
                "Method": "DELETE",
                "Path": "/apis/batch/v1/namespaces/dataloader/jobs/global-reconciliator-customer",
                "QueryParameters": {
                  "propagationPolicy": [
                    "Foreground"
                  ]
                }
              },
              "Resource": "arn:aws:states:::eks:call",
              "ResultPath": "$.response",
              "Type": "Task",
              "Next": "Run Global Reconciliation Customer"
            },
            "Run Global Reconciliation Customer": {
              "Parameters": {
                "CertificateAuthority": "",
                "ClusterName": "data-migration",
                "Endpoint": "${eks_endpoint}",
                "Job": {
                  "apiVersion": "batch/v1",
                  "kind": "Job",
                  "metadata": {
                    "name": "global-reconciliator-customer",
                    "namespace": "dataloader"
                  },
                  "spec": {
                    "template": {
                      "spec": {
                        "serviceAccountName": "data-migration-services",
                        "containers": [
                          {
                            "name": "global-reconciliator-customer",
                            "image": "${global_reconciliation_image}",
                            "env": [
                              {
                                "name": "ENTITY",
                                "value": "customer"
                              }
                            ]
                          }
                        ],
                        "nodeSelector": {
                          "eks.amazonaws.com/nodegroup": "private-nodes"
                        },
                        "restartPolicy": "Never"
                      }
                    },
                    "backoffLimit": 0
                  }
                },
                "Namespace": "dataloader"
              },
              "Resource": "arn:aws:states:::eks:runJob.sync",
              "ResultPath": "$.response",
              "Type": "Task",
              "End": true
            }
          }
        },
        {
          "StartAt": "EKS delete account job",
          "States": {
            "EKS delete account job": {
              "Catch": [
                {
                  "Comment": "eks job doesn't exist",
