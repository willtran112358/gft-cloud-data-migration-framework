                                "value": "account"
                              }
                            ]
                          }
                        ],
                        "nodeSelector": {
                          "eks.amazonaws.com/nodegroup": "private-nodes"
                        },
                        "restartPolicy": "Never"
                      }
                    },
                    "backoffLimit": 0
                  }
                },
                "Namespace": "dataloader"
              },
              "Resource": "arn:aws:states:::eks:runJob.sync",
              "ResultPath": "$.response",
              "Type": "Task",
              "End": true
            }
          }
        },
        {
          "StartAt": "EKS delete posting job",
          "States": {
            "EKS delete posting job": {
              "Catch": [
                {
                  "Comment": "eks job doesn't exist",
                  "ErrorEquals": [
                    "States.TaskFailed"
                  ],
                  "Next": "Run Global Reconciliation Posting"
                }
              ],
              "Parameters": {
                "CertificateAuthority": "",
                "ClusterName": "data-migration",
