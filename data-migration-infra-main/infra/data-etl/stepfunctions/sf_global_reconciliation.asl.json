                  },
                  "spec": {
                    "template": {
                      "spec": {
                        "serviceAccountName": "data-migration-services",
                        "containers": [
                          {
                            "name": "global-reconciliator-posting",
                            "image": "${global_reconciliation_image}",
                            "env": [
                              {
                                "name": "ENTITY",
                                "value": "posting"
                              }
                            ]
                          }
                        ],
                        "nodeSelector": {
                          "eks.amazonaws.com/nodegroup": "private-nodes"
                        },
                        "restartPolicy": "Never"
                      }
                    },
                    "backoffLimit": 0
                  }
                },
                "Namespace": "dataloader"
              },
              "Resource": "arn:aws:states:::eks:runJob.sync",
              "ResultPath": "$.response",
              "Type": "Task",
              "End": true
            }
          }
        }
      ],
      "End": true
    }
  }
}