              "Next": "Run Global Reconciliation Account"
            },
            "Run Global Reconciliation Account": {
              "Parameters": {
                "CertificateAuthority": "",
                "ClusterName": "data-migration",
                "Endpoint": "${eks_endpoint}",
                "Job": {
                  "apiVersion": "batch/v1",
                  "kind": "Job",
                  "metadata": {
                    "name": "global-reconciliator-account",
